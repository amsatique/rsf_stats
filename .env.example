# RallySimFans credentials (https://rallysimfans.hu)
# Copy this file to `.env` and fill in the values. NEVER commit `.env`.
RSF_USERNAME=<your_username>
RSF_PASSWORD=<your_password>

# Optional: dashboard host/port
RSF_HOST=0.0.0.0
RSF_PORT=8000

# Optional: delay between individual scraping requests (seconds), to be gentle on the server
RSF_REQUEST_DELAY=0.5

# Optional: how long a scraped snapshot is reused before re-scraping (seconds)
RSF_CACHE_TTL=600

# Optional: how long stage leaderboards are cached (seconds); they change slowly
RSF_LEADERBOARD_TTL=21600

# Optional: SQLite file for completion history and followed drivers
RSF_DB_PATH=rsf_stats.db

# Optional: log level (DEBUG traces every request to the server)
RSF_LOG_LEVEL=INFO
